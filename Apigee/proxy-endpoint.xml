<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<!--
  Proxy Endpoint — define o BasePath público do proxy.

  O Apigee faz strip do BasePath antes de encaminhar ao backend,
  portanto o servidor .NET expõe apenas /hello (sem /mtls).
-->
<ProxyEndpoint name="default">
    <HTTPProxyConnection>
        <BasePath>/mtls</BasePath>
        <VirtualHost>secure</VirtualHost>
    </HTTPProxyConnection>
    <RouteRule name="default">
        <TargetEndpoint>default</TargetEndpoint>
    </RouteRule>
</ProxyEndpoint>
